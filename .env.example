# .env.example — copy to .env and fill in real values
DB_NAME=pickly
DB_URL=jdbc:mysql://your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:3306/pickly?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=admin
DB_PASSWORD=changeme
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,https://pickly-eta.vercel.app
OAUTH2_REDIRECT_URI=https://pickly-eta.vercel.app/oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
S3_BUCKET=your-bucket-name
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KAKAO_REST_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
